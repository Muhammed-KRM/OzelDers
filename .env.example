# Bu dosyayı kopyalayıp .env olarak kaydedin ve değerleri doldurun.
# .env dosyası GIT'E GÖNDERİLMEZ (.gitignore'da tanımlı).

# Veritabanı
DB_PASSWORD=guclu_bir_sifre_buraya

# JWT — minimum 32 karakter, rastgele üretin
JWT_KEY=en_az_32_karakter_rastgele_bir_string_buraya!!

# AES Şifreleme — tam olarak 32 karakter
AES_KEY=tam_32_karakter_aes_anahtari_bur!

# Admin hesabı (ilk kurulumda bir kez kullanılır, sonra değiştirin)
ADMIN_EMAIL=admin@sirketiniz.com
ADMIN_PASSWORD=Guclu_Bir_Sifre_123!

# Elasticsearch (production)
ELASTIC_PASSWORD=elastic_sifre_buraya
