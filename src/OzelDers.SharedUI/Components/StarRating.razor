@* StarRating Component — Döküman satır 343 *@

<div class="star-rating">
    @for (int i = 1; i <= 5; i++)
    {
        var star = i;
        <span class="star @(star <= Rating ? "filled" : "")"
              @onclick="() => OnRatingChanged.InvokeAsync(star)">
            @(star <= Rating ? "★" : "☆")
        </span>
    }
    @if (ShowValue)
    {
        <span class="rating-value">@Rating.ToString("F1")</span>
    }
</div>

@code {
    [Parameter] public double Rating { get; set; }
    [Parameter] public bool ShowValue { get; set; } = true;
    [Parameter] public EventCallback<int> OnRatingChanged { get; set; }
}
