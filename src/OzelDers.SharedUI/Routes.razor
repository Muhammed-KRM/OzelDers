@using Microsoft.AspNetCore.Components.Routing

<Router AppAssembly="@typeof(Routes).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
            <Authorizing>
                <div class="container section text-center">
                    <p class="text-muted">Güvenlik kontrolü yapılıyor, lütfen bekleyin...</p>
                </div>
            </Authorizing>
            <NotAuthorized>
                @if (!context.User.Identity?.IsAuthenticated ?? true)
                {
                    <div class="container section text-center py-20">
                        <div class="card glass" style="max-width: 500px; margin: 0 auto; padding: 3rem;">
                            <h3>401 - Yetkisiz Erişim</h3>
                            <p class="text-muted mb-8">Bu sayfayı görüntülemek için giriş yapmalısınız.</p>
                            <a href="/giris" class="btn btn-primary" style="width: 100%;">Giriş Yap</a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="container section text-center py-20">
                        <div class="card glass" style="max-width: 500px; margin: 0 auto; padding: 3rem;">
                            <h3>403 - Erişim Reddedildi</h3>
                            <p class="text-muted mb-8">Bu sayfaya erişim yetkiniz bulunmamaktadır.</p>
                            <a href="/" class="btn btn-secondary" style="width: 100%;">Geri Dön</a>
                        </div>
                    </div>
                }
            </NotAuthorized>
        </AuthorizeRouteView>
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(MainLayout)">
            <div class="container text-center section py-20">
                <h1>404</h1>
                <p>Aradığınız sayfa bulunamadı.</p>
                <a href="/" class="btn btn-primary">Ana Sayfaya Dön</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
