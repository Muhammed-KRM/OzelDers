@page "/fake-payment"
@using System.Web
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject HttpClient Http

<PageTitle>Güvenli Ödeme Arayüzü | OzelDers.com</PageTitle>

<section class="section py-20 flex-center">
    <div class="container" style="max-width: 500px;">
        <div class="card glass animate-slide-up" style="border-radius: var(--radius-xl); padding: 3rem 2rem; max-width: 500px; width: 100%; margin: 0 auto; border-top: 5px solid var(--color-primary);">
            
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; border-bottom: 1px solid var(--color-border); padding-bottom: 1rem;">
                <h3 style="color: var(--color-secondary); margin: 0; display: flex; align-items: center; gap: 0.5rem;">
                    🔒 Güvenli Ödeme
                </h3>
                <div style="font-size: 1.5rem; letter-spacing: 2px;">💳</div>
            </div>

            <div class="text-left mb-6">
                <p class="text-xs text-muted" style="margin-bottom: 1.5rem; text-align: center; background: var(--color-primary-light); color: var(--color-primary); padding: 0.5rem; border-radius: var(--radius-sm);">
                    ⚠️ Test Ortamı: Gerçek bir ücret kesintisi yaşanmaz. Herhangi bir numara girebilirsiniz.
                </p>

                <form @onsubmit="ProcessPayment">
                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                        <div>
                            <label class="font-bold text-sm" style="display: block; margin-bottom: 0.4rem; color: var(--color-secondary);">Kart Üzerindeki İsim</label>
                            <input type="text" class="search-input" style="width: 100%; border: 1px solid var(--color-border); background: var(--color-background); border-radius: var(--radius-sm); padding: 0.8rem;" placeholder="AD SOYAD" required minlength="5" />
                        </div>
                        
                        <div>
                            <label class="font-bold text-sm" style="display: block; margin-bottom: 0.4rem; color: var(--color-secondary);">Kart Numarası</label>
                            <input type="text" class="search-input" style="width: 100%; border: 1px solid var(--color-border); background: var(--color-background); border-radius: var(--radius-sm); padding: 0.8rem; font-family: monospace;" placeholder="4543 **** **** ****" required minlength="16" maxlength="19" pattern="\d{16,19}" title="Sadece 16 haneli numaralar giriniz (Boşluksuz)" />
                        </div>

                        <div style="display: flex; gap: 1rem;">
                            <div style="flex: 1;">
                                <label class="font-bold text-sm" style="display: block; margin-bottom: 0.4rem; color: var(--color-secondary);">Son Kullanma (AY/YIL)</label>
                                <input type="text" class="search-input" style="width: 100%; border: 1px solid var(--color-border); background: var(--color-background); border-radius: var(--radius-sm); padding: 0.8rem;" placeholder="MM/YY" required minlength="5" maxlength="5" />
                            </div>
                            <div style="flex: 1;">
                                <label class="font-bold text-sm" style="display: block; margin-bottom: 0.4rem; color: var(--color-secondary);">Güvenlik Kodu (CVV)</label>
                                <input type="text" class="search-input" style="width: 100%; border: 1px solid var(--color-border); background: var(--color-background); border-radius: var(--radius-sm); padding: 0.8rem;" placeholder="123" required minlength="3" maxlength="3" pattern="\d{3}" title="Sadece 3 haneli rakam" />
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%; font-size: 1.1rem; padding: 1.2rem; box-shadow: var(--shadow-md); margin-top: 2rem;" disabled="@isProcessing">
                        @(isProcessing ? "Ödeme İşleniyor..." : "🔒 Ödemeyi Tamamla")
                    </button>
                    
                    <button type="button" class="btn btn-outline mt-4" style="width: 100%;" @onclick="CancelPayment">
                        İşlemi İptal Et
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private bool isProcessing = false;

    private async Task ProcessPayment()
    {
        isProcessing = true;
        await JS.InvokeVoidAsync("ozelders.showSwal", "success", "Tebrikler!", "Ödeme simülasyonu başarılı. Yönlendiriliyorsunuz...", 2000);
        await Task.Delay(2100);

        if (!string.IsNullOrEmpty(ReturnUrl))
        {
            var absoluteUrl = HttpUtility.UrlDecode(ReturnUrl);
            var uri = new Uri(absoluteUrl);
            var relativePath = uri.PathAndQuery;

            try
            {
                var content = new FormUrlEncodedContent(new Dictionary<string, string> { { "status", "success" } });
                var callbackResponse = await Http.PostAsync(relativePath, content);

                Navigation.NavigateTo("/panel/jetonlarim?status=success", forceLoad: true);
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("console.error", "Callback Hata:", ex.Message);
                Navigation.NavigateTo("/panel/jetonlarim?status=error", forceLoad: true);
            }
        }
        else
        {
            Navigation.NavigateTo("/panel/jetonlarim");
        }
    }

    private void CancelPayment()
    {
        Navigation.NavigateTo("/panel/jetonlarim");
    }
}
