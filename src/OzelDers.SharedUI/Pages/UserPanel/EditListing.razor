@inject IListingService ListingService
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>İlan Düzenle | OzelDers.com</PageTitle>

<section class="section edit-listing-page">
    <div class="container">
        <div class="page-header">
            <h1>İlanı Düzenle</h1>
            <p class="text-muted">İlan bilgilerinizi güncelleyin</p>
        </div>

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>İlan yükleniyor...</p>
            </div>
        }
        else if (model == null)
        {
            <div class="alert alert-danger">
                İlan bulunamadı veya erişim yetkiniz yok.
            </div>
        }
        else
        {
            <div class="form-container card">
                <EditForm Model="model" OnValidSubmit="HandleSubmit">
                    <div class="form-section">
                        <h2>İlan Türü</h2>
                        <div class="info-badge">
                            <span class="badge-icon">@(model.Type == ListingType.TeacherOffering ? "👨‍🏫" : "👨‍🎓")</span>
                            <span class="badge-text">@(model.Type == ListingType.TeacherOffering ? "Öğretmen İlanı" : "Öğrenci İlanı")</span>
                            <span class="badge-note">(Değiştirilemez)</span>
                        </div>
                    </div>

                    <!-- Temel Bilgiler -->
                    <div class="form-section">
                        <h2>Temel Bilgiler</h2>
                        
                        <div class="form-group">
                            <label>İlan Başlığı <span class="required">*</span></label>
                            <input type="text" @bind="model.Title" class="form-input" 
                                   placeholder="Örn: Deneyimli Matematik Öğretmeni" maxlength="100" />
                            <span class="form-hint">Dikkat çekici ve açıklayıcı bir başlık yazın</span>
                        </div>

                        <div class="form-group">
                            <label>Açıklama <span class="required">*</span></label>
                            <textarea @bind="model.Description" class="form-textarea" rows="6"
                                      placeholder="Kendinizi, deneyimlerinizi ve ders verme tarzınızı anlatın..." maxlength="1000"></textarea>
                            <span class="form-hint">@(model.Description?.Length ?? 0) / 1000 karakter</span>
                        </div>
                    </div>

                    <!-- Ders Detayları -->
                    <div class="form-section">
                        <h2>Ders Detayları</h2>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label>Branş <span class="required">*</span></label>
                                <select @bind="model.BranchId" class="form-select">
                                    <option value="0">Branş Seçin</option>
                                    @foreach (var branch in branches)
                                    {
                                        <option value="@branch.Id">@branch.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Ders Türü <span class="required">*</span></label>
                                <select @bind="model.LessonType" class="form-select">
                                    <option value="@LessonType.FaceToFace">Yüz Yüze</option>
                                    <option value="@LessonType.Online">Online</option>
                                    <option value="@LessonType.Both">Her İkisi</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Saatlik Ücret (TL) <span class="required">*</span></label>
                            <div class="input-with-icon">
                                <span class="input-icon">💰</span>
                                <input type="number" @bind="model.HourlyPrice" class="form-input" 
                                       placeholder="0" min="0" max="10000" />
                                <span class="input-suffix">TL/saat</span>
                            </div>
                            <span class="form-hint">Piyasa ortalamasına uygun bir fiyat belirleyin</span>
                        </div>
                    </div>

                    <!-- Konum -->
                    <div class="form-section">
                        <h2>Konum Bilgileri</h2>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label>Şehir <span class="required">*</span></label>
                                <select @bind="selectedCityId" @bind:after="LoadDistricts" class="form-select">
                                    <option value="0">Şehir Seçin</option>
                                    @foreach (var city in cities)
                                    {
                                        <option value="@city.Id">@city.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>İlçe <span class="required">*</span></label>
                                <select @bind="model.DistrictId" class="form-select" disabled="@(districts.Count == 0)">
                                    <option value="0">İlçe Seçin</option>
                                    @foreach (var district in districts)
                                    {
                                        <option value="@district.Id">@district.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- İlan Durumu -->
                    <div class="form-section">
                        <h2>İlan Durumu</h2>
                        <div class="form-group">
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="model.IsActive" />
                                <span>İlan aktif (Arama sonuçlarında görünsün)</span>
                            </label>
                        </div>
                    </div>

                    <!-- Hata Mesajı -->
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">
                            @errorMessage
                        </div>
                    }

                    <!-- Form Aksiyonları -->
                    <div class="form-actions">
                        <button type="button" class="btn btn-secondary" @onclick="Cancel">
                            İptal
                        </button>
                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span>Kaydediliyor...</span>
                            }
                            else
                            {
                                <span>✓ Değişiklikleri Kaydet</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        }
    </div>
</section>

@code {
    [Parameter]
    public Guid ListingId { get; set; }

    private ListingUpdateDto? model;
    private List<BranchDto> branches = new();
    private List<CityDto> cities = new();
    private List<DistrictDto> districts = new();
    private int selectedCityId = 0;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadFormData();
        await LoadListing();
    }

    private async Task LoadListing()
    {
        try
        {
            await JS.InvokeVoidAsync("console.log", $"[OzelDers Tracker] İlan detayları çekiliyor: {ListingId}");
            var listing = await ListingService.GetByIdAsync(ListingId);
            
            if (listing != null)
            {
                model = new ListingUpdateDto
                {
                    Type = listing.Type,
                    Title = listing.Title,
                    Description = listing.Description,
                    BranchId = branches.FirstOrDefault(b => b.Name == listing.BranchName)?.Id ?? 0,
                    LessonType = listing.LessonType,
                    HourlyPrice = listing.HourlyPrice,
                    DistrictId = 0,
                    IsActive = listing.Status == ListingStatus.Active
                };
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error", "[OzelDers Tracker] HATA: İlan yüklenenemedi.", ex.Message);
            model = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadFormData()
    {
        try
        {
            var branchResult = await Http.GetFromJsonAsync<List<BranchDto>>("api/branches");
            if (branchResult != null) branches = branchResult;

            var cityResult = await Http.GetFromJsonAsync<List<CityDto>>("api/cities");
            if (cityResult != null) cities = cityResult;
            
            await LoadDistricts();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error", "[OzelDers Tracker] HATA: Form verileri (branş/şehir) yüklenemedi.", ex.Message);
        }
    }

    private async Task LoadDistricts()
    {
        districts.Clear();

        if (selectedCityId > 0)
        {
            try
            {
                districts = new List<DistrictDto>
                {
                    new() { Id = 1, Name = "Kadıköy" },
                    new() { Id = 2, Name = "Beşiktaş" }
                };
            }
            catch
            {
                // API henüz çalışmıyorsa
            }
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;
        isSubmitting = true;

        try
        {
            if (string.IsNullOrWhiteSpace(model?.Title))
            {
                errorMessage = "İlan başlığı zorunludur.";
                return;
            }

            if (model.BranchId == 0)
            {
                errorMessage = "Lütfen bir branş seçin.";
                return;
            }

            if (model.DistrictId == 0)
            {
                errorMessage = "Lütfen şehir ve ilçe seçin.";
                return;
            }

            await JS.InvokeVoidAsync("console.log", $"[OzelDers Tracker] İlan güncelleniyor: {ListingId}");
            
            await ListingService.UpdateAsync(ListingId, model, Guid.Empty);
            
            await JS.InvokeVoidAsync("console.log", "[OzelDers Tracker] BAŞARILI: İlan güncellendi.");
            Navigation.NavigateTo("/panel/ilanlarim");
        }
        catch (Exception ex)
        {
            errorMessage = "İlan güncellenirken bir hata oluştu: " + ex.Message;
            await JS.InvokeVoidAsync("console.error", "[OzelDers Tracker] HATA: İlan güncellenemedi.", ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/panel/ilanlarim");
    }
}
