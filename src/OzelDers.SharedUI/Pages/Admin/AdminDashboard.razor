@page "/admin"
@page "/admin/dashboard"
@attribute [Authorize(Roles = "Admin")]
@using OzelDers.Business.DTOs
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Admin Paneli | OzelDers.com</PageTitle>

<section class="section admin-dashboard">
    <div class="container">
        <!-- Başlık -->
        <div class="page-header">
            <div class="header-content">
                <h1>🎛️ Admin Paneli</h1>
                <button class="btn btn-secondary" @onclick="LoadDashboard">
                    🔄 Yenile
                </button>
            </div>
            <p class="text-muted">Sistem genel bakış ve yönetim</p>
        </div>

        @if (isLoading)
        {
            <div class="loading-overlay">
                <div class="spinner"></div>
                <p>İstatistikler yükleniyor...</p>
            </div>
        }

        <!-- İstatistik Kartları -->
        <div class="stats-grid">
            <div class="stat-card card">
                <div class="stat-icon users">👥</div>
                <div class="stat-content">
                    <h3 class="stat-number">@stats.TotalUsers</h3>
                    <p class="stat-label">Toplam Kullanıcı</p>
                    <span class="stat-change neutral">@stats.TotalTeachers Öğretmen</span>
                </div>
            </div>

            <div class="stat-card card">
                <div class="stat-icon listings">📋</div>
                <div class="stat-content">
                    <h3 class="stat-number">@stats.TotalListings</h3>
                    <p class="stat-label">Toplam İlan</p>
                    <span class="stat-change positive">@stats.ActiveListings Aktif</span>
                </div>
            </div>

            <div class="stat-card card">
                <div class="stat-icon messages">💬</div>
                <div class="stat-content">
                    <h3 class="stat-number">@stats.TotalMessages</h3>
                    <p class="stat-label">Toplam Mesaj</p>
                    <span class="stat-change warning">@stats.PendingListings Bekleyen İlan</span>
                </div>
            </div>

            <div class="stat-card card">
                <div class="stat-icon revenue">💰</div>
                <div class="stat-content">
                    <h3 class="stat-number">@stats.TotalRevenue.ToString("N0") TL</h3>
                    <p class="stat-label">Toplam Ciro</p>
                </div>
            </div>
        </div>

        <!-- Hızlı Aksiyonlar -->
        <div class="quick-actions card">
            <h2>⚡ Hızlı İşlemler</h2>
            <div class="actions-grid">
                <button class="action-btn" @onclick='() => Navigation.NavigateTo("/admin/users")'>
                    <span class="action-icon">👥</span>
                    <span class="action-text">Kullanıcı Yönetimi</span>
                </button>
                <button class="action-btn" @onclick='() => Navigation.NavigateTo("/admin/listings")'>
                    <span class="action-icon">📋</span>
                    <span class="action-text">İlan Yönetimi</span>
                </button>
                <button class="action-btn" @onclick='() => Navigation.NavigateTo("/admin/reports")'>
                    <span class="action-icon">📊</span>
                    <span class="action-text">Raporlar</span>
                </button>
                <button class="action-btn" @onclick="ClearCache">
                    <span class="action-icon">🗑️</span>
                    <span class="action-text">Cache Temizle</span>
                </button>
            </div>
        </div>

        <!-- Son Aktiviteler -->
        <div class="recent-activity card">
            <h2>📌 Son Aktiviteler</h2>
            <div class="activity-list">
                @if (stats.RecentActivities == null || !stats.RecentActivities.Any())
                {
                    <p class="text-muted p-20 text-center">Henüz aktivite bulunmuyor.</p>
                }
                else
                {
                    @foreach (var activity in stats.RecentActivities)
                    {
                        <div class="activity-item">
                            <div class="activity-icon">@activity.Icon</div>
                            <div class="activity-content">
                                <p class="activity-text">@activity.Description</p>
                                <span class="activity-time">@activity.CreatedAt.ToString("g")</span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Sistem Durumu -->
        <div class="system-status card">
            <h2>🔧 Sistem Durumu</h2>
            <div class="status-grid">
                <div class="status-item">
                    <span class="status-label">API</span>
                    <span class="status-badge online">🟢 Aktif</span>
                </div>
                <div class="status-item">
                    <span class="status-label">Veritabanı</span>
                    <span class="status-badge online">🟢 Bağlı</span>
                </div>
                <div class="status-item">
                    <span class="status-label">Mail Servisi</span>
                    <span class="status-badge online">🟢 Hazır</span>
                </div>
                <div class="status-item">
                    <span class="status-label">Dosya Servisi</span>
                    <span class="status-badge online">🟢 Hazır</span>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private AdminDashboardDto stats = new();
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        isLoading = true;
        try
        {
            stats = await Http.GetFromJsonAsync<AdminDashboardDto>("api/admin/dashboard") ?? new();
        }
        catch (Exception)
        {
            // Prerendering sırasında JS çağırılamaz, hata sunucu tarafında loglanabilir
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ClearCache()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Sistem önbelleğini temizlemek istediğinize emin misiniz?");
        if (confirmed)
        {
            await JS.InvokeVoidAsync("alert", "Sistem önbelleği başarıyla temizlendi.");
        }
    }
}
