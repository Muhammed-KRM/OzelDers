@page "/admin/listings"
@attribute [Authorize(Roles = "Admin")]
@using OzelDers.Business.DTOs
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>İlan Yönetimi | Admin Panel</PageTitle>

<section class="section listing-management">
    <div class="container">
        <PageHeader Title="İlan Yönetimi" Subtitle="Tüm ilanları görüntüleyin ve yönetin" BackUrl="/admin">
            <Actions>
                <button class="btn btn-secondary" @onclick="LoadListings">🔄 Yenile</button>
            </Actions>
        </PageHeader>

        <!-- Filtre ve Arama -->
        <div class="filters-bar card">
            <div class="search-box">
                <span class="search-icon">🔍</span>
                <input type="text" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearch"
                       class="search-input" placeholder="İlan başlığı veya öğretmen adı ile ara..." />
            </div>

            <div class="filter-group">
                <select @bind="filterStatus" @bind:after="LoadListings" class="filter-select">
                    <option value="">Tüm Durumlar</option>
                    <option value="Active">Aktif</option>
                    <option value="Pending">Onay Bekliyor</option>
                    <option value="Rejected">Reddedildi</option>
                    <option value="Suspended">Askıya Alındı</option>
                </select>

                <select @bind="filterType" @bind:after="LoadListings" class="filter-select">
                    <option value="">Tüm Türler</option>
                    <option value="Teacher">Öğretmen</option>
                    <option value="Student">Öğrenci</option>
                </select>

                <button class="btn btn-secondary" @onclick="ResetFilters">
                    Filtreleri Temizle
                </button>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="loading-overlay">
                <div class="spinner"></div>
                <p>İlanlar yükleniyor...</p>
            </div>
        }

        <!-- İlan Listesi -->
        <div class="listings-grid">
            @foreach (var listing in listings)
            {
                <div class="listing-card card">
                    @if (listing.IsVitrin)
                    {
                        <div class="vitrin-badge">⭐ Vitrin</div>
                    }

                    <div class="listing-header">
                        <div class="listing-type @listing.Type.ToLower()">
                            @(listing.Type == "Teacher" ? "👨‍🏫 Öğretmen" : "👨‍🎓 Öğrenci")
                        </div>
                        <div class="listing-status @listing.Status.ToLower()">
                            @listing.Status
                        </div>
                    </div>

                    <h3 class="listing-title">@listing.Title</h3>
                    
                    <div class="listing-meta">
                        <div class="meta-item">
                            <span class="meta-icon">👤</span>
                            <span>@listing.TeacherName</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-icon">📚</span>
                            <span>@listing.Branch</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-icon">📍</span>
                            <span>@listing.City</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-icon">💰</span>
                            <span>@listing.HourlyPrice TL/saat</span>
                        </div>
                    </div>

                    <div class="listing-stats">
                        <div class="stat-item">
                            <span class="stat-value">@listing.ViewCount</span>
                            <span class="stat-label">Görüntülenme</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-value">@listing.MessageCount</span>
                            <span class="stat-label">Mesaj</span>
                        </div>
                    </div>

                    <div class="listing-date">
                        Oluşturulma: @listing.CreatedAt.ToString("dd.MM.yyyy")
                    </div>

                    <div class="listing-actions">
                        <button class="btn-action view" @onclick="() => ViewListing(listing.Id)">
                            👁️ Görüntüle
                        </button>
                        @if (listing.Status == "Pending")
                        {
                            <button class="btn-action approve" @onclick="() => ApproveListing(listing.Id)">
                                ✅ Onayla
                            </button>
                            <button class="btn-action reject" @onclick="() => RejectListing(listing.Id)">
                                ❌ Reddet
                            </button>
                        }
                        else if (listing.Status == "Active")
                        {
                            <button class="btn-action suspend" @onclick="() => SuspendListing(listing.Id)">
                                🚫 Askıya Al
                            </button>
                        }
                        <button class="btn-action delete" @onclick="() => DeleteListing(listing.Id)">
                            🗑️ Sil
                        </button>
                    </div>
                </div>
            }
        </div>

        @if (!listings.Any() && !isLoading)
        {
            <div class="empty-state card">
                <div class="empty-icon">📭</div>
                <p>İlan bulunamadı</p>
            </div>
        }
    </div>
</section>

@code {
    private List<AdminListingDto> listings = new();
    private string searchQuery = string.Empty;
    private string filterStatus = string.Empty;
    private string filterType = string.Empty;
    private bool isLoading = false;
    private System.Timers.Timer? searchTimer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadListings();
            StateHasChanged();
        }
    }

    private async Task LoadListings()
    {
        isLoading = true;
        try
        {
            var url = $"api/admin/listings?search={searchQuery}&status={filterStatus}&type={filterType}";
            listings = await Http.GetFromJsonAsync<List<AdminListingDto>>(url) ?? new();
        }
        catch (Exception)
        {
            // Prerendering sırasında JS çağırılamaz
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void HandleSearch()
    {
        searchTimer?.Stop();
        searchTimer?.Dispose();
        searchTimer = new System.Timers.Timer(500);
        searchTimer.Elapsed += async (s, e) =>
        {
            searchTimer.Stop();
            await InvokeAsync(LoadListings);
        };
        searchTimer.Start();
    }

    private async Task ResetFilters()
    {
        searchQuery = string.Empty;
        filterStatus = string.Empty;
        filterType = string.Empty;
        await LoadListings();
    }

    private void ViewListing(Guid listingId) => Navigation.NavigateTo($"/ilan/{listingId}");

    private async Task ApproveListing(Guid listingId)
    {
        try
        {
            var response = await Http.PutAsync($"api/admin/listings/{listingId}/approve", null);
            if (response.IsSuccessStatusCode) await LoadListings();
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", "Hata: " + ex.Message); }
    }

    private async Task RejectListing(Guid listingId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Bu ilanı reddetmek istediğinize emin misiniz?");
        if (!confirmed) return;

        try
        {
            var response = await Http.PutAsync($"api/admin/listings/{listingId}/reject", null);
            if (response.IsSuccessStatusCode) await LoadListings();
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", "Hata: " + ex.Message); }
    }

    private async Task SuspendListing(Guid listingId)
    {
        try
        {
            var response = await Http.PutAsync($"api/admin/listings/{listingId}/suspend", null);
            if (response.IsSuccessStatusCode) await LoadListings();
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", "Hata: " + ex.Message); }
    }

    private async Task DeleteListing(Guid listingId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Bu ilanı SİLMEK istediğinize emin misiniz? Bu işlem geri alınamaz.");
        if (!confirmed) return;

        try
        {
            var response = await Http.DeleteAsync($"api/admin/listings/{listingId}");
            if (response.IsSuccessStatusCode) await LoadListings();
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", "Hata: " + ex.Message); }
    }
}
