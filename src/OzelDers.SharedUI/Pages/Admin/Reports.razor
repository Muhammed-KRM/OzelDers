@page "/admin/reports"
@attribute [Authorize(Roles = "Admin")]
@using OzelDers.Business.DTOs
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Raporlar | Admin Panel</PageTitle>

<section class="section reports-page">
    <div class="container">
        <!-- Başlık -->
        <div class="page-header">
            <div class="header-content">
                <h1>📊 Raporlar ve Analitik</h1>
                <div class="header-actions">
                     <button class="btn btn-secondary" @onclick="LoadData">
                        🔄 Yenile
                    </button>
                    <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/admin")'>
                        ← Panele Dön
                    </button>
                </div>
            </div>
            <p class="text-muted">Sistem performansı ve istatistikler</p>
        </div>

        @if (isLoading)
        {
            <div class="loading-overlay">
                <div class="spinner"></div>
                <p>Veriler yükleniyor...</p>
            </div>
        }

        <!-- Genel İstatistikler -->
        <div class="stats-section">
            <h2>📈 Genel İstatistikler</h2>
            <div class="stats-grid">
                <div class="stat-card card">
                    <div class="stat-header">
                        <span class="stat-icon">👥</span>
                        <h3>Kullanıcılar</h3>
                    </div>
                    <div class="stat-body">
                        <div class="stat-row">
                            <span>Toplam Kullanıcı:</span>
                            <strong>@stats.TotalUsers</strong>
                        </div>
                        <div class="stat-row">
                            <span>Öğretmen Sayısı:</span>
                            <strong>@stats.TotalTeachers</strong>
                        </div>
                        <div class="stat-row">
                            <span>Öğrenci Sayısı:</span>
                            <strong>@stats.TotalStudents</strong>
                        </div>
                    </div>
                </div>

                <div class="stat-card card">
                    <div class="stat-header">
                        <span class="stat-icon">📋</span>
                        <h3>İlanlar</h3>
                    </div>
                    <div class="stat-body">
                        <div class="stat-row">
                            <span>Toplam İlan:</span>
                            <strong>@stats.TotalListings</strong>
                        </div>
                        <div class="stat-row">
                            <span>Aktif İlan:</span>
                            <strong class="positive">@stats.ActiveListings</strong>
                        </div>
                        <div class="stat-row">
                            <span>Onay Bekleyen:</span>
                            <strong class="warning">@stats.PendingListings</strong>
                        </div>
                    </div>
                </div>

                <div class="stat-card card">
                    <div class="stat-header">
                        <span class="stat-icon">💬</span>
                        <h3>İletişim</h3>
                    </div>
                    <div class="stat-body">
                        <div class="stat-row">
                            <span>Toplam Mesaj:</span>
                            <strong>@stats.TotalMessages</strong>
                        </div>
                        <div class="stat-row">
                            <span>Sistem Sağlığı:</span>
                            <strong class="positive">Mükemmel</strong>
                        </div>
                    </div>
                </div>

                <div class="stat-card card">
                    <div class="stat-header">
                        <span class="stat-icon">💰</span>
                        <h3>Finansal</h3>
                    </div>
                    <div class="stat-body">
                        <div class="stat-row">
                            <span>Toplam Ciro:</span>
                            <strong class="positive">@stats.TotalRevenue.ToString("N0") TL</strong>
                        </div>
                        <div class="stat-row">
                            <span>Para Birimi:</span>
                            <strong>TRY</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Jeton İstatistikleri -->
        <div class="token-stats card">
            <h2>🪙 Jeton Satış Dağılımı</h2>
            <div class="package-distribution">
                @if (packageSales == null || !packageSales.Any())
                {
                    <p class="text-muted text-center p-20">Henüz satış verisi bulunmuyor.</p>
                }
                else
                {
                    @foreach (var package in packageSales)
                    {
                        <div class="package-bar">
                            <div class="package-info">
                                <span class="package-name">@package.Name</span>
                                <span class="package-count">@package.SalesCount satış</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: @package.Percentage%"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Popüler Branşlar -->
        <div class="popular-branches card">
            <h2>📚 En Popüler Branşlar</h2>
            <div class="branches-list">
                @if (popularBranches == null || !popularBranches.Any())
                {
                    <p class="text-muted text-center p-20">Veri bulunamadı.</p>
                }
                else
                {
                    @foreach (var branch in popularBranches)
                    {
                        <div class="branch-item">
                            <span class="branch-rank">@branch.Rank</span>
                            <span class="branch-name">@branch.Name</span>
                            <span class="branch-count">@branch.ListingCount ilan</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</section>

@code {
    private AdminDashboardDto stats = new();
    private bool isLoading = false;
    private List<PackageSaleDto> packageSales = new();
    private List<AdminBranchDto> popularBranches = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            stats = await Http.GetFromJsonAsync<AdminDashboardDto>("api/admin/dashboard") ?? new();
            
            // Branch ve Paket istatistikleri için ayrı endpoint'ler ileride eklenebilir.
            // Şimdilik dashboard verisini kullanıyoruz.
            LoadMockMeta();
        }
        catch (Exception)
        {
            // Prerendering sırasında JS çağırılamaz
        }
        finally
        {
            isLoading = false;
        }
    }

    private void LoadMockMeta()
    {
        // Meta veriler (Henüz API'de olmayanlar için şimdilik mock)
        packageSales = new List<PackageSaleDto>
        {
            new() { Name = "Popüler (10 Jeton)", SalesCount = 145, Percentage = 45 },
            new() { Name = "Profesyonel (25 Jeton)", SalesCount = 89, Percentage = 28 },
            new() { Name = "Başlangıç (5 Jeton)", SalesCount = 67, Percentage = 21 }
        };

        popularBranches = new List<AdminBranchDto>
        {
            new() { Rank = 1, Name = "Matematik", ListingCount = 234 },
            new() { Rank = 2, Name = "İngilizce", ListingCount = 189 },
            new() { Rank = 3, Name = "Fizik", ListingCount = 145 }
        };
    }
}
