@page "/admin/reports"
@attribute [Authorize(Roles = "Admin")]
@using OzelDers.Business.DTOs
@inject NavigationManager Navigation

<PageTitle>Raporlar | Admin Panel</PageTitle>

<section class="section reports-page">
    <div class="container">
        <!-- Başlık -->
        <div class="page-header">
            <div class="header-content">
                <h1>📊 Raporlar ve Analitik</h1>
                <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/admin")'>
                    ← Panele Dön
                </button>
            </div>
            <p class="text-muted">Sistem performansı ve istatistikler</p>
        </div>

        <!-- Tarih Filtresi -->
        <div class="date-filter card">
            <div class="filter-group">
                <label>
                    <span>Başlangıç Tarihi:</span>
                    <input type="date" @bind="startDate" class="date-input" />
                </label>
                <label>
                    <span>Bitiş Tarihi:</span>
                    <input type="date" @bind="endDate" class="date-input" />
                </label>
                <button class="btn btn-secondary" @onclick="ApplyDateFilter">
                    Filtrele
                </button>
                <button class="btn btn-secondary" @onclick="ExportReport">
                    📥 Rapor İndir (CSV)
                </button>
            </div>
        </div>

        <!-- Genel İstatistikler -->
        <div class="stats-section">
            <h2>📈 Genel İstatistikler</h2>
            <div class="stats-grid">
                <div class="stat-card card">
                    <div class="stat-header">
                        <span class="stat-icon">👥</span>
                        <h3>Kullanıcılar</h3>
                    </div>
                    <div class="stat-body">
                        <div class="stat-row">
                            <span>Toplam Kullanıcı:</span>
                            <strong>@totalUsers</strong>
                        </div>
                        <div class="stat-row">
                            <span>Yeni Kayıtlar (Bu Ay):</span>
                            <strong class="positive">+@newUsersThisMonth</strong>
                        </div>
                        <div class="stat-row">
                            <span>Aktif Kullanıcı:</span>
                            <strong>@activeUsers</strong>
                        </div>
                    </div>
                </div>

                <div class="stat-card card">
                    <div class="stat-header">
                        <span class="stat-icon">📋</span>
                        <h3>İlanlar</h3>
                    </div>
                    <div class="stat-body">
                        <div class="stat-row">
                            <span>Toplam İlan:</span>
                            <strong>@totalListings</strong>
                        </div>
                        <div class="stat-row">
                            <span>Aktif İlan:</span>
                            <strong>@activeListings</strong>
                        </div>
                        <div class="stat-row">
                            <span>Onay Bekleyen:</span>
                            <strong class="warning">@pendingListings</strong>
                        </div>
                    </div>
                </div>

                <div class="stat-card card">
                    <div class="stat-header">
                        <span class="stat-icon">💬</span>
                        <h3>Mesajlaşma</h3>
                    </div>
                    <div class="stat-body">
                        <div class="stat-row">
                            <span>Toplam Mesaj:</span>
                            <strong>@totalMessages</strong>
                        </div>
                        <div class="stat-row">
                            <span>Bu Ay:</span>
                            <strong class="positive">+@messagesThisMonth</strong>
                        </div>
                        <div class="stat-row">
                            <span>Ortalama Yanıt Süresi:</span>
                            <strong>@avgResponseTime saat</strong>
                        </div>
                    </div>
                </div>

                <div class="stat-card card">
                    <div class="stat-header">
                        <span class="stat-icon">💰</span>
                        <h3>Gelir</h3>
                    </div>
                    <div class="stat-body">
                        <div class="stat-row">
                            <span>Toplam Gelir:</span>
                            <strong>@totalRevenue TL</strong>
                        </div>
                        <div class="stat-row">
                            <span>Bu Ay:</span>
                            <strong class="positive">+@revenueThisMonth TL</strong>
                        </div>
                        <div class="stat-row">
                            <span>Ortalama İşlem:</span>
                            <strong>@avgTransaction TL</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Jeton İstatistikleri -->
        <div class="token-stats card">
            <h2>🪙 Jeton İstatistikleri</h2>
            <div class="token-grid">
                <div class="token-item">
                    <span class="token-label">Satılan Toplam Jeton:</span>
                    <span class="token-value">@totalTokensSold</span>
                </div>
                <div class="token-item">
                    <span class="token-label">Harcanan Toplam Jeton:</span>
                    <span class="token-value">@totalTokensSpent</span>
                </div>
                <div class="token-item">
                    <span class="token-label">Aktif Jeton Bakiyesi:</span>
                    <span class="token-value">@activeTokenBalance</span>
                </div>
                <div class="token-item">
                    <span class="token-label">Jeton Geliri:</span>
                    <span class="token-value">@tokenRevenue TL</span>
                </div>
            </div>

            <h3>Paket Satış Dağılımı</h3>
            <div class="package-distribution">
                @foreach (var package in packageSales)
                {
                    <div class="package-bar">
                        <div class="package-info">
                            <span class="package-name">@package.Name</span>
                            <span class="package-count">@package.SalesCount satış</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: @package.Percentage%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Vitrin İstatistikleri -->
        <div class="vitrin-stats card">
            <h2>⭐ Vitrin İstatistikleri</h2>
            <div class="vitrin-grid">
                <div class="vitrin-item">
                    <span class="vitrin-label">Aktif Vitrin İlanı:</span>
                    <span class="vitrin-value">@activeVitrinListings</span>
                </div>
                <div class="vitrin-item">
                    <span class="vitrin-label">Toplam Vitrin Satışı:</span>
                    <span class="vitrin-value">@totalVitrinSales</span>
                </div>
                <div class="vitrin-item">
                    <span class="vitrin-label">Vitrin Geliri:</span>
                    <span class="vitrin-value">@vitrinRevenue TL</span>
                </div>
                <div class="vitrin-item">
                    <span class="vitrin-label">Ortalama Vitrin Süresi:</span>
                    <span class="vitrin-value">@avgVitrinDuration gün</span>
                </div>
            </div>
        </div>

        <!-- Popüler Branşlar -->
        <div class="popular-branches card">
            <h2>📚 En Popüler Branşlar</h2>
            <div class="branches-list">
                @foreach (var branch in popularBranches)
                {
                    <div class="branch-item">
                        <span class="branch-rank">@branch.Rank</span>
                        <span class="branch-name">@branch.Name</span>
                        <span class="branch-count">@branch.ListingCount ilan</span>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@code {
    private DateTime startDate = DateTime.Now.AddMonths(-1);
    private DateTime endDate = DateTime.Now;

    // Genel İstatistikler
    private int totalUsers = 1247;
    private int newUsersThisMonth = 156;
    private int activeUsers = 892;
    private int totalListings = 856;
    private int activeListings = 734;
    private int pendingListings = 23;
    private int totalMessages = 3421;
    private int messagesThisMonth = 487;
    private int avgResponseTime = 4;
    private decimal totalRevenue = 45680;
    private decimal revenueThisMonth = 8920;
    private decimal avgTransaction = 187;

    // Jeton İstatistikleri
    private int totalTokensSold = 4567;
    private int totalTokensSpent = 3892;
    private int activeTokenBalance = 675;
    private decimal tokenRevenue = 28450;

    private List<PackageSaleDto> packageSales = new();

    // Vitrin İstatistikleri
    private int activeVitrinListings = 45;
    private int totalVitrinSales = 234;
    private decimal vitrinRevenue = 17230;
    private int avgVitrinDuration = 22;

    // Popüler Branşlar
    private List<AdminBranchDto> popularBranches = new();

    protected override void OnInitialized()
    {
        LoadPackageSales();
        LoadPopularBranches();
    }

    private void LoadPackageSales()
    {
        packageSales = new List<PackageSaleDto>
        {
            new() { Name = "Popüler (10 Jeton)", SalesCount = 145, Percentage = 45 },
            new() { Name = "Profesyonel (25 Jeton)", SalesCount = 89, Percentage = 28 },
            new() { Name = "Başlangıç (5 Jeton)", SalesCount = 67, Percentage = 21 },
            new() { Name = "Kurumsal (50 Jeton)", SalesCount = 23, Percentage = 6 }
        };
    }

    private void LoadPopularBranches()
    {
        popularBranches = new List<AdminBranchDto>
        {
            new() { Rank = 1, Name = "Matematik", ListingCount = 234 },
            new() { Rank = 2, Name = "İngilizce", ListingCount = 189 },
            new() { Rank = 3, Name = "Fizik", ListingCount = 145 },
            new() { Rank = 4, Name = "Kimya", ListingCount = 123 },
            new() { Rank = 5, Name = "Türkçe", ListingCount = 98 }
        };
    }

    private void ApplyDateFilter()
    {
        // Tarih filtresine göre verileri yeniden yükle
    }

    private void ExportReport()
    {
        // CSV rapor oluştur ve indir
    }

}
