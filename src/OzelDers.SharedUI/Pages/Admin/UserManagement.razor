@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@using OzelDers.Business.DTOs
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Kullanıcı Yönetimi | Admin Panel</PageTitle>

<section class="section user-management">
    <div class="container">
        <!-- Başlık ve Filtreler -->
        <div class="page-header">
            <div class="header-content">
                <h1>👥 Kullanıcı Yönetimi</h1>
                <div class="header-actions">
                    <button class="btn btn-secondary" @onclick="LoadUsers">
                        🔄 Yenile
                    </button>
                    <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/admin")'>
                        ← Panele Dön
                    </button>
                </div>
            </div>
            <p class="text-muted">Tüm kullanıcıları görüntüleyin ve yönetin</p>
        </div>

        <!-- Filtre ve Arama -->
        <div class="filters-bar card">
            <div class="search-box">
                <span class="search-icon">🔍</span>
                <input type="text" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearch"
                       class="search-input" placeholder="Ad, e-posta ile ara..." />
            </div>

            <div class="filter-group">
                <select @bind="filterRole" @bind:after="LoadUsers" class="filter-select">
                    <option value="">Tüm Roller</option>
                    <option value="Teacher">Öğretmen</option>
                    <option value="Student">Öğrenci</option>
                    <option value="Admin">Admin</option>
                </select>

                <select @bind="filterStatus" @bind:after="LoadUsers" class="filter-select">
                    <option value="">Tüm Durumlar</option>
                    <option value="Active">Aktif</option>
                    <option value="Suspended">Askıya Alınmış</option>
                </select>

                <button class="btn btn-secondary" @onclick="ResetFilters">
                    Filtreleri Temizle
                </button>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="loading-overlay">
                <div class="spinner"></div>
                <p>Kullanıcılar yükleniyor...</p>
            </div>
        }

        <!-- Kullanıcı Tablosu -->
        <div class="users-table card">
            <table>
                <thead>
                    <tr>
                        <th>Kullanıcı</th>
                        <th>E-posta</th>
                        <th>Telefon</th>
                        <th>Rol</th>
                        <th>Durum</th>
                        <th>Kayıt Tarihi</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in users)
                    {
                        <tr>
                            <td class="user-cell">
                                <div class="user-avatar">@(string.IsNullOrEmpty(user.FullName) ? "?" : user.FullName[0].ToString())</div>
                                <div class="user-info">
                                    <strong>@user.FullName</strong>
                                    <span class="user-id">ID: @user.Id.ToString().Substring(0, 8)</span>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>@user.Phone</td>
                            <td>
                                <span class="role-badge @(user.Role?.ToLower() ?? "unknown")">@user.Role</span>
                            </td>
                            <td>
                                <span class="status-badge @(user.Status?.ToLower() ?? "unknown")">@user.Status</span>
                            </td>
                            <td class="date-cell">@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td class="actions-cell">
                                @if (user.Status == "Active")
                                {
                                    <button class="action-icon-btn danger" @onclick="() => SuspendUser(user.Id)" title="Askıya Al">
                                        🚫
                                    </button>
                                }
                                else
                                {
                                    <button class="action-icon-btn success" @onclick="() => ActivateUser(user.Id)" title="Aktifleştir">
                                        ✅
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!users.Any() && !isLoading)
            {
                <div class="empty-state">
                    <div class="empty-icon">🔍</div>
                    <p>Kullanıcı bulunamadı</p>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private List<AdminUserDto> users = new();
    private string searchQuery = string.Empty;
    private string filterRole = string.Empty;
    private string filterStatus = string.Empty;
    private bool isLoading = false;
    private System.Timers.Timer? searchTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        try
        {
            var url = $"api/admin/users?search={searchQuery}&role={filterRole}&status={filterStatus}";
            users = await Http.GetFromJsonAsync<List<AdminUserDto>>(url) ?? new();
        }
        catch (Exception)
        {
            // Prerendering sırasında JS çağırılamaz
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void HandleSearch()
    {
        searchTimer?.Stop();
        searchTimer?.Dispose();
        searchTimer = new System.Timers.Timer(500);
        searchTimer.Elapsed += async (s, e) =>
        {
            searchTimer.Stop();
            await InvokeAsync(LoadUsers);
        };
        searchTimer.Start();
    }

    private async Task ResetFilters()
    {
        searchQuery = string.Empty;
        filterRole = string.Empty;
        filterStatus = string.Empty;
        await LoadUsers();
    }

    private async Task SuspendUser(Guid userId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Bu kullanıcıyı askıya almak istediğinize emin misiniz?");
        if (!confirmed) return;

        try
        {
            var response = await Http.PutAsync($"api/admin/users/{userId}/suspend", null);
            if (response.IsSuccessStatusCode)
            {
                await LoadUsers();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Hata: " + ex.Message);
        }
    }

    private async Task ActivateUser(Guid userId)
    {
        try
        {
            var response = await Http.PutAsync($"api/admin/users/{userId}/activate", null);
            if (response.IsSuccessStatusCode)
            {
                await LoadUsers();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Hata: " + ex.Message);
        }
    }
}
