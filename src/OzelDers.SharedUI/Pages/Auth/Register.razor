@page "/kayit"

<PageTitle>Ücretsiz Kayıt | OzelDers.com</PageTitle>

<section class="section">
    <div class="container">
        <div class="auth-card card">
            <h2 class="text-center">Ücretsiz Kayıt Ol</h2>
            <p class="text-center text-muted">Kayıt olanlara 3 jeton hediye! 🎁</p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <EditForm Model="registerModel" OnValidSubmit="HandleRegister">
                <div class="form-group">
                    <label>Ad Soyad</label>
                    <input type="text" @bind="registerModel.FullName" class="form-input" placeholder="Ad Soyad" />
                </div>
                <div class="form-group">
                    <label>E-posta</label>
                    <input type="email" @bind="registerModel.Email" class="form-input" placeholder="ornek@email.com" />
                </div>
                <div class="form-group">
                    <label>Şifre</label>
                    <input type="password" @bind="registerModel.Password" class="form-input" placeholder="En az 8 karakter" />
                </div>
                <button type="submit" class="btn btn-primary btn-full">Kayıt Ol</button>
            </EditForm>

            <p class="text-center text-muted" style="margin-top: 1rem;">
                Zaten hesabınız var mı? <a href="/giris">Giriş Yap</a>
            </p>
        </div>
    </div>
</section>

@code {
    private UserRegisterDto registerModel = new();
    private string? errorMessage;

    private async Task HandleRegister()
    {
        // API entegrasyonunda implement edilecek
    }
}
