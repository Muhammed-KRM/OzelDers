@page "/"
@inject IListingService ListingService

<PageTitle>Özel Ders Bul | OzelDers.com</PageTitle>

<!-- 1. Hero Section -->
<section class="hero-section">
    <div class="container">
        <h1 class="hero-title animate-slide-up">Aradığın <span>Öğretmeni</span> Bul</h1>
        <p class="hero-subtitle animate-fade-in">Türkiye'nin en güvenilir özel ders platformunda binlerce uzman öğretmen seni bekliyor.</p>
        <div class="search-container animate-fade-in" style="background: white; padding: 0.75rem; border-radius: 50px; display: inline-flex; align-items: center; width: 100%; max-width: 600px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); margin: 0 auto;">
            <span style="padding-left: 1rem; font-size: 1.5rem;">🔍</span>
            <input type="text" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleKeyDown"
                   style="border: none; outline: none; padding: 1rem; flex-grow: 1; font-size: 1.1rem; border-radius: 50px;" 
                   placeholder="Ne öğrenmek istersin? (Matematik, İngilizce...)" />
            <button class="btn btn-primary" @onclick="ExecuteSearch" style="border-radius: 40px; padding: 1rem 2rem; font-weight: bold;">Hemen Bul</button>
        </div>
    </div>
</section>

<!-- 2. Popüler Kategoriler -->
<section class="section">
    <div class="container">
        <h2 class="text-center">Popüler Kategoriler</h2>
        <div class="grid grid-4 category-grid">
            <a href="/arama?branch=matematik" class="category-card animate-float">
                <span class="category-icon">📐</span>
                <span>Matematik</span>
            </a>
            <a href="/arama?branch=ingilizce" class="category-card animate-float" style="animation-delay: 0.2s">
                <span class="category-icon">🌍</span>
                <span>İngilizce</span>
            </a>
            <a href="/arama?branch=fizik" class="category-card animate-float" style="animation-delay: 0.4s">
                <span class="category-icon">⚛️</span>
                <span>Fizik</span>
            </a>
            <a href="/arama?branch=yazilim-csharp" class="category-card animate-float" style="animation-delay: 0.6s">
                <span class="category-icon">💻</span>
                <span>Yazılım</span>
            </a>
        </div>
    </div>
</section>

<!-- 3. Vitrin İlanları -->
<section class="section py-20" style="background: rgba(255,255,255,0.4)">
    <div class="container">
        <h2 class="text-center font-bold">✨ Öne Çıkan Eğitmenler</h2>
        @if (vitrinListings.Any())
        {
            <div class="grid grid-3">
                @foreach (var listing in vitrinListings)
                {
                    <ListingCard Listing="listing" />
                }
            </div>
        }
        else
        {
            <div class="text-center padding-xl glass" style="border-radius: var(--radius-lg)">
                <p class="text-muted">Henüz vitrin ilanı bulunmamaktadır.</p>
            </div>
        }
    </div>
</section>

<!-- 4. Nasıl Çalışır -->
<section class="section">
    <div class="container">
        <h2 class="text-center mb-12">Ders Almaya Hemen Başla</h2>
        <div class="grid grid-3 gap-8">
            <div class="step-card">
                <div class="step-number">1</div>
                <h3>Eğitmeni Seç</h3>
                <p>Binlerce profil arasından sana en uygun olanı gelişmiş filtrelerle bul.</p>
            </div>
            <div class="step-card">
                <div class="step-number">2</div>
                <h3>Tanışma Mesajı At</h3>
                <p>İlana ücretsiz başvur ya da jetonunla öğretmene direkt teklif gönder.</p>
            </div>
            <div class="step-card">
                <div class="step-number">3</div>
                <h3>Eğitime Başla</h3>
                <p>Öğretmeninle detayları konuş ve hedefine doğru ilk adımı at!</p>
            </div>
        </div>
    </div>
</section>

<!-- 5. İstatistikler -->
<section class="section" style="background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); color: white; padding: 4rem 0;">
    <div class="container">
        <div class="grid grid-4 gap-8 text-center">
            <div class="stat-box">
                <div style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.25rem;">1,200+</div>
                <div style="opacity: 0.85; font-weight: 500;">Eğitmen</div>
            </div>
            <div class="stat-box">
                <div style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.25rem;">3,500+</div>
                <div style="opacity: 0.85; font-weight: 500;">Aktif İlan</div>
            </div>
            <div class="stat-box">
                <div style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.25rem;">50+</div>
                <div style="opacity: 0.85; font-weight: 500;">Branş</div>
            </div>
            <div class="stat-box">
                <div style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.25rem;">8,000+</div>
                <div style="opacity: 0.85; font-weight: 500;">Mutlu Öğrenci</div>
            </div>
        </div>
    </div>
</section>

<!-- 6. CTA -->
<div class="container mb-12">
    <section class="cta-section glass-dark animate-slide-up">
        <h2>Öğretmen misiniz?</h2>
        <p>Hemen ücretsiz kayıt olun, tecrübenizi binlerce öğrenciyle paylaşmaya başlayın.</p>
        <div class="flex justify-center gap-4">
            <a href="/kayit" class="btn btn-primary btn-lg">Şimdi Kayıt Ol</a>
            <a href="/nasil-calisir" class="btn btn-outline btn-lg" style="color: white; border-color: rgba(255,255,255,0.3)">Nasıl Çalışır?</a>
        </div>
    </section>
</div>

@using Microsoft.JSInterop
@code {
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    
    private List<ListingDto> vitrinListings = new();
    private string searchQuery = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try { vitrinListings = await ListingService.GetVitrinListingsAsync(); }
        catch { /* API henüz çalışmıyorsa sessizce geç */ }
    }

    private async Task ExecuteSearch()
    {
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            await JS.InvokeVoidAsync("console.log", $"[OzelDers Tracker] Arama yapılıyor: {searchQuery}");
            NavManager.NavigateTo($"/arama?q={Uri.EscapeDataString(searchQuery)}");
        }
        else
        {
            await JS.InvokeVoidAsync("console.log", "[OzelDers Tracker] Boş arama yapıldı, tüm listeye yönlendiriliyor.");
            NavManager.NavigateTo("/arama");
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ExecuteSearch();
    }
}
